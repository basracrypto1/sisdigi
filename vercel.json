{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/citizens/batch", "destination": "/api/citizens/batch" },
    { "source": "/api/citizens/:id", "destination": "/api/citizens/[id]" },
    { "source": "/api/letters/:id", "destination": "/api/letters/[id]" },
    { "source": "/api/citizens", "destination": "/api/citizens" },
    { "source": "/api/letters", "destination": "/api/letters" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
